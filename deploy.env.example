# ─────────────────────────────────────────────────────────
# FlotaControl — Configuración de Deploy para Ubuntu Server
# Copiar a /etc/flotacontrol/.env en el servidor
# ─────────────────────────────────────────────────────────

# Base de datos MySQL/MariaDB
DB_HOST=127.0.0.1
DB_USER=flotacontrol
DB_PASS=CAMBIAR_PASSWORD_SEGURO
DB_NAME=flotacontrol
# DB_SOCKET=/var/run/mysqld/mysqld.sock  # Descomentar si usa socket

# Aplicación
APP_DEBUG=false
APP_NAME=FlotaControl
APP_URL=https://tu-dominio.com

# Directorio de uploads (ruta absoluta)
# Por defecto usa /var/www/flotacontrol/uploads
# Para disco secundario de 500GB:
# UPLOAD_PATH=/mnt/data/flotacontrol/uploads

# Purga automática de órdenes de compra (días)
OC_PURGE_DAYS=180

# PHP
PHP_MAX_UPLOAD=20M
PHP_POST_MAX=25M
PHP_MEMORY_LIMIT=256M
