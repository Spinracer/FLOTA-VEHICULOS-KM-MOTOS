# FlotaControl — ejemplo de entorno
# Copia este archivo a .env y completa los valores

# ─── Base de datos (OBLIGATORIO) ───
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=flotacontrol
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Aplicación ───
APP_NAME=FlotaControl
APP_ENV=production
APP_URL=http://localhost
APP_DEBUG=false
APP_SECRET=

# ─── Sesiones ───
SESSION_NAME=FLOTACONTROL
SESSION_LIFETIME=7200

# ─── Primer usuario admin (solo primera instalación) ───
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# ─── Docker (solo para docker-compose) ───
MYSQL_ROOT_PASSWORD=
APP_PORT=8080
DB_EXTERNAL_PORT=3307
TZ=America/Tegucigalpa
